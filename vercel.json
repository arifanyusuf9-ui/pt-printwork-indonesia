{
    "version": 2,
    "name": "printwork-web",
    "builds": [
        { "src": "server.js", "use": "@vercel/node" },
        { "src": "*.html", "use": "@vercel/static" },
        { "src": "identity-printwork.png", "use": "@vercel/static" },
        { "src": "logo.png", "use": "@vercel/static" },
        { "src": "style.css", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "server.js" },
        { "src": "/(.*)", "dest": "/$1" }
    ]
}